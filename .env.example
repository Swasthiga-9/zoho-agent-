# ── Zoho Projects ─────────────────────────────────────────────────────────────
# Get access token from: https://api-console.zoho.com/
# Scopes needed: ZohoProjects.tasks.ALL, ZohoProjects.portals.READ
ZOHO_ACCESS_TOKEN=your_zoho_oauth_access_token_here
ZOHO_PORTAL=your_portal_name         # from URL: zoho.com/projects/portal/YOUR_PORTAL
ZOHO_PROJECT_ID=your_project_id      # from URL: .../projects/YOUR_PROJECT_ID

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail (use App Password, not account password) ────────────────────────────
# Enable App Passwords: myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Reviewers (both receive all escalation emails) ────────────────────────────
SIVA_EMAIL=siva@yourdomain.com
DHINESH_EMAIL=officialswasthika@gmail.com

# ── Escalation Rules ──────────────────────────────────────────────────────────
ESCALATION_DAYS=7                    # days in progress before escalation
DIGEST_INACTIVITY_HOURS=24           # hours of no activity before daily digest
KEYWORDS=blocked,urgent,overdue,review needed,stuck,waiting,delayed
